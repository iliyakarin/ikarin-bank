# Environment
ENV=development
NEXT_PUBLIC_ENV=development

# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=[REDACTED]
POSTGRES_DB=banking_db
# Set to 'postgres' for Docker Compose, 'localhost' for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse Configuration
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=banking_log
CLICKHOUSE_USER=readonly_admin
CLICKHOUSE_PASSWORD=[REDACTED]
# Pre-computed SHA256 hex of CLICKHOUSE_PASSWORD (used by readonly-user.xml)
# Generate with:  echo -n "YOUR_PASSWORD" | sha256sum | awk '{print $1}'
CLICKHOUSE_READONLY_PASSWORD_SHA256=[REDACTED]

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=bank_transactions
KAFKA_USER=admin
KAFKA_PASSWORD=[REDACTED]
KAFKA_ADMIN_PASSWORD=[REDACTED]
KAFKA_CLIENT_PASSWORD=[REDACTED]
CLUSTER_ID=[REDACTED]
KAFKA_LISTENER_NAME_SASL_PLAINTEXT_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="admin" password="[REDACTED]" user_admin="[REDACTED]" user_kafka="[REDACTED]";

# JWT Configuration
SECRET_KEY=[REDACTED]

# Application Configuration
CORS_ORIGINS=http://localhost:3000,https://us-bank-dev.iliyakarin.com
ACCOUNT_ENCRYPTION_KEY=[REDACTED]
TUNNEL_TOKEN=[REDACTED]

# Mock Fed Gateway & Vendor Simulator
GATEWAY_API_KEY=[REDACTED]
SIMULATOR_API_KEY=[REDACTED]
SIMULATOR_URL=http://vendor-simulator:8001
# For local tests outside docker, you might use http://localhost:8001
SIMULATOR_LOCAL_URL=http://localhost:8001
FED_GATEWAY_DB_USER=admin
FED_GATEWAY_DB_PASSWORD=[REDACTED]
FED_GATEWAY_DB_NAME=fed_gateway_db
FED_GATEWAY_DB_URL=postgresql+asyncpg://${FED_GATEWAY_DB_USER}:${FED_GATEWAY_DB_PASSWORD}@fed-gateway-db:5432/${FED_GATEWAY_DB_NAME}

# Vendor Simulator Database
VENDOR_SIMULATOR_DB_USER=admin
VENDOR_SIMULATOR_DB_PASSWORD=[REDACTED]
VENDOR_SIMULATOR_DB_NAME=vendor_simulator_db
VENDOR_SIMULATOR_DB_URL=postgresql+asyncpg://${VENDOR_SIMULATOR_DB_USER}:${VENDOR_SIMULATOR_DB_PASSWORD}@vendor-simulator-db:5432/${VENDOR_SIMULATOR_DB_NAME}

# Cloudflare Turnstile (Testing Keys)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=[REDACTED]
TURNSTILE_SECRET_KEY=[REDACTED]
# PostgreSQL Config
POSTGRES_USER=admin
POSTGRES_PASSWORD=[REDACTED]
POSTGRES_DB=banking_db
# Set to 'postgres' for Docker Compose, 'localhost' for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432


# Security config
SECRET_KEY=[REDACTED]
CORS_ORIGINS=http://localhost:3000

# Initial Admin Setup
ADMIN_EMAIL=[REDACTED]
ADMIN_PASSWORD=[REDACTED]

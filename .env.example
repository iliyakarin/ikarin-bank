# Environment
ENV=development
NEXT_PUBLIC_ENV=development

# PostgreSQL Config
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=banking_db
# Set to 'postgres' for Docker Compose, 'localhost' for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse Config
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=banking_log
CLICKHOUSE_USER=your_clickhouse_user
CLICKHOUSE_PASSWORD=your_secure_clickhouse_password
CLICKHOUSE_ADMIN_USER=your_clickhouse_admin_user
CLICKHOUSE_ADMIN_PASSWORD=your_secure_clickhouse_admin_password

# Pre-computed SHA256 hex of CLICKHOUSE_PASSWORD (used by readonly-user.xml)
# Generate with:  echo -n "YOUR_PASSWORD" | sha256sum | awk '{print $1}'
CLICKHOUSE_READONLY_PASSWORD_SHA256=your_sha256_hash_here
AUDIT_LOGGER_USER=your_audit_logger_user
AUDIT_LOGGER_PASSWORD=your_secure_audit_logger_password

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=bank_transactions
KAFKA_USER=your_kafka_user
KAFKA_PASSWORD=your_secure_kafka_password
KAFKA_ADMIN_PASSWORD=your_secure_kafka_admin_password
KAFKA_CLIENT_PASSWORD=your_secure_kafka_client_password
CLUSTER_ID=your_cluster_id_here
KAFKA_LISTENER_NAME_SASL_PLAINTEXT_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="your_kafka_user" password="your_secure_kafka_password" user_admin="your_secure_kafka_admin_password" user_kafka="your_secure_kafka_client_password";

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application Configuration
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
ACCOUNT_ENCRYPTION_KEY=your_account_encryption_key_here
# TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Deposit Service Mock Configuration
DEPOSIT_MOCK_API_KEY=sk_test_mock_deposit_key_12345
DEPOSIT_MOCK_WEBHOOK_SECRET=whsec_mock_webhook_secret_12345
DEPOSIT_MOCK_URL=http://deposit-funds-mock:8000
NEXT_PUBLIC_DEPOSIT_MOCK_PUBLISHABLE_KEY=pk_test_mock_deposit_key_12345

# Mock Fed Gateway & Vendor Simulator
GATEWAY_API_KEY=your_secure_gateway_api_key
SIMULATOR_API_KEY=your_secure_simulator_api_key
SIMULATOR_URL=http://vendor-simulator:8001
# For local tests outside docker, you might use http://localhost:8001
SIMULATOR_LOCAL_URL=http://localhost:8001
FED_GATEWAY_DB_USER=your_fed_gateway_db_user
FED_GATEWAY_DB_PASSWORD=your_secure_fed_gateway_db_password
FED_GATEWAY_DB_NAME=fed_gateway_db
FED_GATEWAY_DB_URL=postgresql+asyncpg://${FED_GATEWAY_DB_USER}:${FED_GATEWAY_DB_PASSWORD}@fed-gateway-db:5432/${FED_GATEWAY_DB_NAME}

# Vendor Simulator Database
VENDOR_SIMULATOR_DB_USER=your_vendor_simulator_db_user
VENDOR_SIMULATOR_DB_PASSWORD=your_secure_vendor_simulator_db_password
VENDOR_SIMULATOR_DB_NAME=vendor_simulator_db
VENDOR_SIMULATOR_DB_URL=postgresql+asyncpg://${VENDOR_SIMULATOR_DB_USER}:${VENDOR_SIMULATOR_DB_PASSWORD}@vendor-simulator-db:5432/${VENDOR_SIMULATOR_DB_NAME}

# Cloudflare Turnstile (Mandatory for production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Initial Admin Setup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password

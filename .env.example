# =============================================================================
# Karin Bank — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control!
# =============================================================================

# PostgreSQL Config
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=banking_db
# Set to 'postgres' for Docker Compose, 'localhost' for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse Config
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=readonly_admin
CLICKHOUSE_PASSWORD=CHANGE_ME
# Pre-computed SHA256 hex of CLICKHOUSE_PASSWORD (used by readonly-user.xml)
# Generate with:  echo -n "YOUR_PASSWORD" | sha256sum | awk '{print $1}'
CLICKHOUSE_READONLY_PASSWORD_SHA256=CHANGE_ME

# Kafka Config
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=bank_transactions
KAFKA_USER=admin
KAFKA_PASSWORD=CHANGE_ME

# JWT — generate a strong random key!
# Example:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME

# Application
CORS_ORIGINS=http://localhost:3000

# PostgreSQL Config
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=banking_db
# Set to 'postgres' for Docker Compose, 'localhost' for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse Config
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=your_clickhouse_user
CLICKHOUSE_PASSWORD=your_secure_clickhouse_password
CLICKHOUSE_DB=banking_log

# Kafka Config
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_USER=your_kafka_user
KAFKA_PASSWORD=your_secure_kafka_password
KAFKA_TOPIC=bank_transactions

# Security config
SECRET_KEY=generate_a_secure_secret_key_here
CORS_ORIGINS=http://localhost:3000

# Initial Admin Setup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password

# Captcha config (Mandatory for production)
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Cloudflare Tunnel (Optional)
CLOUDFLARE_TUNNEL_TOKEN=

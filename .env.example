# PostgreSQL Config
POSTGRES_USER=admin
POSTGRES_PASSWORD=[REDACTED]
POSTGRES_DB=banking_db
# Set to 'postgres' for Docker Compose, 'localhost' for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse Config
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=bank_secure_pass_2025
# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# Kafka Config
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_USER=admin
KAFKA_PASSWORD=kafka_secure_pass_2025
KAFKA_TOPIC=bank_transactions

# Security config
SECRET_KEY=[REDACTED]
CORS_ORIGINS=http://localhost:3000

# Initial Admin Setup
ADMIN_EMAIL=[REDACTED]
ADMIN_PASSWORD=[REDACTED]

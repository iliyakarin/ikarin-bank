<clickhouse>
    <users>
        <readonly_admin>
            <password_sha256_hex from_env="CLICKHOUSE_READONLY_PASSWORD_SHA256" />
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_rights>
                <grant>SELECT ON banking.transactions</grant>
                <grant>SELECT ON system.tables</grant>
                <grant>SELECT ON system.databases</grant>
            </access_rights>
        </readonly_admin>
    </users>
</clickhouse>
